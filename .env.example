# Neon / Supabase / any hosted Postgres
# For Neon: get from dashboard → Connection Details → "Prisma" mode
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct connection (no pgBouncer) — used by Prisma migrations
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Upstash Redis — get from Upstash console → REST API
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# Public base URL — needed for server-side fetch calls
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Cron secret — Vercel injects this automatically for cron jobs in prod
# Set a random string here for local testing
CRON_SECRET="a-random-secret-string"
